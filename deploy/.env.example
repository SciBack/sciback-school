# ============================================================
# SciBack School — Variables de entorno
# Copiar a .env y completar. NUNCA commitear .env
# ============================================================

# --- Identidad del cliente ---
CLIENT_SLUG=agua-viva
CLIENT_NAME=Comunidad Cristiana Agua Viva
DOMAIN=erp.aguaviva.edu.pe

# --- Odoo ---
ODOO_IMAGE=ghcr.io/sciback/sciback-odoo:17.0-latest
ODOO_MASTER_PASSWORD=CAMBIAR_EN_PRODUCCION
ODOO_DB_NAME=sciback_school
ODOO_ADMIN_EMAIL=admin@aguaviva.edu.pe
# Módulos a instalar en orden (Fase 1)
# website,l10n_pe,openeducat_core,openeducat_admission,openeducat_attendance,openeducat_exam,openeducat_fees,openeducat_timetable,queue_job

# --- PostgreSQL ---
POSTGRES_USER=odoo
POSTGRES_PASSWORD=CAMBIAR_EN_PRODUCCION
POSTGRES_DB=sciback_school
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis (queue_job) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- SUNAT / NubeFact ---
NUBEFACT_TOKEN=
NUBEFACT_RUC=20360093141
NUBEFACT_MODO=demo   # demo | produccion
SUNAT_USUARIO_SOL=
SUNAT_CLAVE_SOL=

# --- Culqi ---
CULQI_PUBLIC_KEY=
CULQI_SECRET_KEY=
CULQI_MODO=sandbox   # sandbox | produccion

# --- AWS (solo en producción, usar Secrets Manager) ---
AWS_REGION=sa-east-1
S3_BUCKET_ADJUNTOS=
S3_BUCKET_BACKUPS=
