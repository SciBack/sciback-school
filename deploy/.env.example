# ============================================================
# SciBack Odoo — Variables de entorno de un POD (multi-tenant)
# Un POD = 1 EC2 + 1 RDS que aloja VARIOS colegios (1 DB c/u).
# Copiar a .env y completar. NUNCA commitear .env
# ============================================================

# --- Identidad del POD ---
POD_ID=pod-1
# Dominio base del pod. Cada colegio entra por <slug>.${BASE_DOMAIN}
# (ej. aguaviva.colegios.sciback.com). Requiere DNS wildcard *.${BASE_DOMAIN}.
BASE_DOMAIN=colegios.sciback.com

# --- Odoo ---
ODOO_IMAGE=ghcr.io/sciback/sciback-odoo:17.0-latest
ODOO_MASTER_PASSWORD=CAMBIAR_EN_PRODUCCION
ODOO_ADMIN_EMAIL=ops@sciback.com
# Multi-tenant: NO se fija una DB (dbfilter resuelve por subdominio).
# Workers del pod: regla 2*vCPU+1. t3.xlarge (4 vCPU) -> 6-8.
ODOO_WORKERS=6
ODOO_CRON_THREADS=2

# --- PostgreSQL (RDS compartido del pod) ---
POSTGRES_USER=odoo
POSTGRES_PASSWORD=CAMBIAR_EN_PRODUCCION
# DB de mantenimiento (las DBs de colegio se crean con nuevo-colegio.sh)
POSTGRES_DB=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis (queue_job) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- SUNAT / NubeFact y pagos: SON POR-COLEGIO ---
# NO van aquí. Se configuran dentro de cada DB en sciback.school.config
# (token NubeFact, RUC, modo, serie; Culqi public/secret). Aislados por colegio.

# --- AWS (producción; preferir Secrets Manager) ---
AWS_REGION=us-east-2
S3_BUCKET_ADJUNTOS=
S3_BUCKET_BACKUPS=
