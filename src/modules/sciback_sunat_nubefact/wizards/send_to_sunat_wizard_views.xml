<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista del wizard -->
    <record id="view_send_to_sunat_wizard_form" model="ir.ui.view">
        <field name="name">send.to.sunat.wizard.form</field>
        <field name="model">send.to.sunat.wizard</field>
        <field name="arch" type="xml">
            <form string="Enviar a SUNAT / NubeFact">
                <group>
                    <field name="move_id" readonly="1"/>
                    <field name="modo"/>
                </group>
                <div class="alert alert-warning" role="alert"
                     invisible="modo != 'produccion'">
                    <strong>Atención:</strong> Está enviando en modo
                    <strong>Producción</strong>. Este comprobante
                    será registrado de forma definitiva ante SUNAT.
                </div>
                <div class="alert alert-info" role="alert"
                     invisible="modo != 'demo'">
                    Modo <strong>Sandbox</strong>: el comprobante se valida
                    en el ambiente de pruebas de NubeFact. No afecta SUNAT real.
                </div>
                <footer>
                    <button name="action_confirmar_envio"
                            string="Confirmar envío"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción para abrir el wizard desde un botón externo si se necesita -->
    <record id="action_send_to_sunat_wizard" model="ir.actions.act_window">
        <field name="name">Enviar a SUNAT</field>
        <field name="res_model">send.to.sunat.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
